generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String      @id @default(cuid())
  email      String      @unique
  name       String?
  image      String?
  emailVerified DateTime?
  createdAt  DateTime    @default(now())
  workspaces Workspace[]
  pages      Page[]
  accounts   Account[]
  sessions   Session[]
  recurringRules RecurringRule[]
  categorizationRules CategorizationRule[]
  savingsGoals SavingsGoal[]
}

model CategorizationRule {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match     String   // lowercased substring matched against vendor
  category  String   // category to force when matched
  createdAt DateTime @default(now())

  @@unique([userId, match])
  @@index([userId])
}

model SavingsGoal {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  targetAmount  Float
  currentAmount Float     @default(0)
  deadline      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
}

model RecurringRule {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String    // 'income' | 'expense'
  name              String    // e.g. "City of Detroit paycheck", "Rent"
  category          String    // must match a Personal Budget Category option
  amount            Float     // always positive — sign applied based on type
  frequency         String    // 'weekly' | 'biweekly' | 'semimonthly' | 'monthly'
  anchorDate        DateTime  // next-due date (advances after each generation)
  lastGeneratedDate DateTime? // most recent occurrence we wrote a row for
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String
  icon      String?
  color     String?
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  pages     Page[]
  databases Database[]
  createdAt DateTime @default(now())

  @@unique([ownerId, slug])
  @@index([ownerId])
}

model Database {
  id          String     @id @default(cuid())
  name        String
  workspaceId String
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pages       Page[]
  properties  Property[]
  views       View[]
  createdAt   DateTime   @default(now())

  @@index([workspaceId])
}

model Property {
  id         String   @id @default(cuid())
  name       String
  type       String   // text, number, date, select, etc.
  formula    String?  // formula expression
  position   Float    @default(0)
  databaseId String
  database   Database @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  values     PropertyValue[]
  createdAt  DateTime @default(now())

  @@index([databaseId, position])
}

model PropertyValue {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  pageId     String
  page       Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  value      Json     // the value, could be string, number, etc.

  @@unique([propertyId, pageId])
  @@index([pageId])
}

model View {
  id         String   @id @default(cuid())
  name       String
  type       String   // table, gallery, list, etc.
  databaseId String
  database   Database @relation(fields: [databaseId], references: [id], onDelete: Cascade)
  filters    Json?    // filter conditions
  sorts      Json?    // sort conditions
  createdAt  DateTime @default(now())

  @@index([databaseId])
}

model Page {
  id           String                  @id @default(cuid())
  title        String                  @default("Untitled")
  icon         String?
  cover        String?
  workspaceId  String
  searchVector Unsupported("tsvector")? @map("search_vector")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  databaseId  String?
  database    Database? @relation(fields: [databaseId], references: [id], onDelete: SetNull)
  parentId    String?
  parent      Page?     @relation("PageHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    Page[]    @relation("PageHierarchy")
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  blocks      Block[]
  properties  PropertyValue[]
  position    Float     @default(0)
  isFavorite  Boolean   @default(false)
  isArchived  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId, parentId])
  @@index([databaseId])
  @@index([authorId])
}

model Block {
  id           String                   @id @default(cuid())
  pageId       String
  page         Page                     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type         String
  content      Json
  position     Float
  canvasX      Float?
  canvasY      Float?
  canvasWidth  Float?
  parentId     String?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  searchVector Unsupported("tsvector")? @map("search_vector")

  @@index([pageId, position])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UsageLog {
  id           String   @id @default(cuid())
  service      String
  operation    String
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  costUsd      Float    @default(0)
  userId       String?
  createdAt    DateTime @default(now())

  @@index([service, createdAt])
  @@index([createdAt])
}
